<%= link_to(image_pack_tag("home.png", alt: 'home', class: 'img-home'), trainings_path, class: 'for-mobile buffer_top_home') %>
<h3 class="center text_size mt-2">Профиль</h3>
<div class="container my-bg-color">
  <div class="row my-3">
    <div class="col-lg-8 order-lg-1 mb-3">

      <h3 class="text_size mt-1"><b><%= @user.name %></h3></b>

      <div><%= image_pack_tag("#{User.rank[User.rank.index{ |x| x[0] == "#{@user.rank}" }][1]}", alt: 'rank-image', class: 'img-rank') %></div>
      <h5 class="text_size mt-1">Ваш статус: <%= t current_user.rank %></h5>
      <h5 class="text_size mt-1">Накоплено богатств: <%= current_user.money.round %> пиастров</h5>
      <div class="buffer-top">
        <div>
        <div>
          <%= link_to 'Достижения', achivements_user_path, class: 'btn btn-secondary mt-2' %>
        </div>
          <%= link_to "Редактировать профиль", edit_user_path(@user), class: 'btn btn-secondary mt-2' %>
        </div>
        <div>
          <%= link_to 'Сменить пароль', edit_user_registration_path, class: 'btn btn-secondary mt-2' %>
        </div>
        <% if current_user.money > 5.0  %>
          <div>
            <%= link_to 'Забрать пиастры', take_money_user_path, class: 'btn btn-danger mt-2' %>
          </div>
        <% end %>
      <div class="mt-3">
        <%= link_to 'Обратно', root_path %>
      </div>
     </div> 
    </div>
  </div>
</div>

